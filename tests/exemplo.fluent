# Fluent Language - Example Program

integer x receives 10;
float pi receives 3.14;
string msg receives "hello";
boolean flag receives true;

integer function max(integer a, integer b) then
    if (a is greater than b) then
        return a;
    else
        return b;
    end
end

boolean function even(integer n) then
    integer half receives n divided by 2;
    if (half times 2 equals n) then
        return true;
    else
        return false;
    end
end

integer counter receives 0;
while (counter is less than 5) then
    if (even(counter)) then
        say("even");
    else
        say("odd");
    end
    counter receives counter plus 1;
end

integer result receives max(x, counter);
say(result);
say(msg);
say(pi);